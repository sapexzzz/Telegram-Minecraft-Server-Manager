# ===== Telegram Bot =====
BOT_TOKEN=your_bot_token_here

# Список Telegram user_id администраторов через запятую
ADMIN_IDS=123456789,987654321

# ===== RCON =====
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# ===== Пути к файлам Minecraft =====
MINECRAFT_LOG_PATH=/opt/minecraft/logs/latest.log
MODS_DIR=/opt/minecraft/mods
WORLD_DIR=/opt/minecraft/world
BACKUP_DIR=/opt/minecraft/backups

# Путь к JAR-файлу запуска сервера
SERVER_JAR=/opt/minecraft/fabric-server-launch.jar

# Имя systemd-юнита сервера (узнать: systemctl list-units | grep minecraft)
SYSTEMD_SERVICE_NAME=minecraft
